{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=TransportManagementDB;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
